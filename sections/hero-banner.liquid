<section class="hero-banner">
    <div class="hero-container">
        <h1>{{ section.settings.heading }}</h1>
        <p>{{ section.settings.subtext }}</p>
        <a href="{{ section.settings.button_link }}" class="hero-btn">
            {{ section.settings.button_text }}
        </a>
    </div>
</section>

{% schema %}
    {
        "name": "Hero Banner" ,
        "settings": [
            {
                "type": "text",
                "id": "heading",
                "label": "Heading",
                "default": "Welcome to Our Store"
            },
            {
                "type": "text",
                "id": "subtext",
                "label": "Subtext",
                "default": "Discover our latest products and offers"
            },
            {
                "type": "url",
                "id": "button_link",
                "label": "Button Link",
            },
            {
                "type": "text",
                "id": "button_text",
                "label": "Button Text",
                "default": "Shop Now"
            }
        ],
        "presets": [
            {
                "name": "Hero Banner"
            }
        ]
    }
{% endschema %}